<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/colorPrimary"
        android:elevation="4dp"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light" />

    <TextView
        android:id="@+id/process_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Check your Nutrition Status"
        android:textSize="18sp"
        android:layout_marginTop="16dp"
        android:layout_below="@+id/toolbar"
        android:layout_centerHorizontal="true" />

    <TextView
        android:id="@+id/age_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Age"
        android:textSize="16sp"
        android:layout_marginTop="10dp"
        android:layout_below="@+id/process_title"
        android:layout_marginHorizontal="16dp" />

    <Spinner
        android:id="@+id/input_age"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:entries="@array/age_array"
        android:layout_below="@id/age_title"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="16dp" />

    <TextView
        android:id="@+id/height_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Height"
        android:textSize="16sp"
        android:layout_marginTop="12dp"
        android:layout_below="@+id/input_age"
        android:layout_marginHorizontal="16dp" />

    <EditText
        android:id="@+id/input_height"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Height (cm)"
        android:inputType="number"
        android:layout_below="@id/height_title"
        android:maxLength="3"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="16dp" />

    <TextView
        android:id="@+id/weight_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Weight"
        android:textSize="16sp"
        android:layout_marginTop="12dp"
        android:layout_below="@+id/input_height"
        android:layout_marginHorizontal="16dp" />

    <EditText
        android:id="@+id/input_weight"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Weight (kg)"
        android:inputType="number"
        android:layout_below="@id/weight_title"
        android:maxLength="3"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="16dp" />

    <TextView
        android:id="@+id/gender_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gender"
        android:textSize="16sp"
        android:layout_marginTop="12dp"
        android:layout_below="@+id/input_weight"
        android:layout_marginHorizontal="16dp" />

    <Spinner
        android:id="@+id/input_gender"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:entries="@array/gender_array"
        android:layout_below="@id/gender_title"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="16dp" />

    <Button
        android:id="@+id/btn_process"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Submit"
        android:layout_below="@id/input_gender"
        android:layout_marginTop="16dp"
        android:layout_marginHorizontal="16dp"
        android:background="@drawable/btn_rounded"/>

</RelativeLayout>
